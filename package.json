{
  "name": "stoodio-md-viewer",
  "productName": "Stoodio MD",
  "version": "1.2.0",
  "description": "A beautiful markdown editor with live preview",
  "author": {
    "name": "Stoodio",
    "email": "hello@stoodio.app"
  },
  "license": "MIT",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "electron . --dev",
    "build": "vite build && cp -r src/main dist/",
    "start": "npm run build && electron .",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:mac:release": "npm run build && electron-builder --mac -c.mac.forceCodeSigning=true",
    "dist:dir": "npm run build && electron-builder --dir && codesign --force --deep --options runtime --entitlements build/entitlements.mac.plist --sign - 'release/mac-arm64/Stoodio MD.app'",
    "resign": "codesign --force --deep --options runtime --entitlements build/entitlements.mac.plist --sign - 'release/mac-arm64/Stoodio MD.app'"
  },
  "build": {
    "appId": "app.stoodio.md",
    "productName": "Stoodio MD",
    "copyright": "Copyright © 2024–2026 Stoodio",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*"
    ],
    "extraMetadata": {
      "main": "dist/main/main.js"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "minimumSystemVersion": "13.0",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        },
        {
          "target": "zip",
          "arch": ["universal"]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Markdown Document",
            "CFBundleTypeRole": "Editor",
            "CFBundleTypeExtensions": ["md", "markdown", "mdown", "mkd"],
            "LSHandlerRank": "Alternate"
          }
        ]
      }
    },
    "dmg": {
      "title": "${productName} ${version}",
      "icon": "build/icon.icns",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "description": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "description": "Markdown Document",
        "role": "Editor"
      }
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.4.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@milkdown/crepe": "^7.6.0"
  }
}
